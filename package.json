{
  "name": "pcpc",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "PCPC monorepo root — frontend (SvelteKit, tested via Vitest), backend/functions (Azure Functions, tested via Jest from this root), backend/shared (@pcpc/shared types).",
  "author": "Michael Abernathy",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Abernaughty/PCPC.git"
  },
  "packageManager": "pnpm@10.32.1",
  "dependencies": {
    "@azure/cosmos": "^4.0.0"
  },
  "devDependencies": {
    "@babel/core": "^8.0.1",
    "@babel/preset-env": "^8.0.1",
    "@jest/globals": "^30.4.1",
    "@playwright/test": "^1.61.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^26.0.1",
    "babel-jest": "^30.4.1",
    "jest": "^30.4.2",
    "jest-junit": "^17.0.0",
    "jest-watch-typeahead": "^3.0.1",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "typescript": "^6.0.3"
  },
  "scripts": {
    "seed-cosmos": "node .devcontainer/scripts/seed-cosmos.mjs",
    "test": "jest --config=jest.config.cjs",
    "test:watch": "jest --config=jest.config.cjs --watch",
    "test:coverage": "jest --config=jest.config.cjs --coverage",
    "test:backend": "jest --config=jest.config.cjs tests/backend",
    "test:e2e": "playwright test --config=tests/config/playwright.config.ts",
    "test:e2e:headed": "playwright test --config=tests/config/playwright.config.ts --headed",
    "test:e2e:debug": "playwright test --config=tests/config/playwright.config.ts --debug",
    "test:performance": "k6 run tests/performance/load/api-endpoints.js",
    "test:security": "npm audit && echo 'Security scan completed'",
    "test:all": "npm run test && npm run test:e2e",
    "playwright:install": "playwright install",
    "playwright:install-deps": "playwright install-deps"
  },
  "jest": {
    "preset": "./jest.config.cjs"
  },
  "pnpm": {
    "overrides": {
      "@opentelemetry/exporter-prometheus": "^0.217.0",
      "@opentelemetry/sdk-node": "^0.217.0",
      "protobufjs": "^8.6.0",
      "cookie": ">=0.7.0",
      "qs": ">=6.15.2",
      "uuid": ">=11.1.1",
      "brace-expansion": ">=5.0.6",
      "devalue": ">=5.8.1"
    }
  }
}
